---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const seriesOrder = [
	'why-this-series-exists',
	'impossible-task',
	'seven-layers',
	'llm-shines-agents-destroy',
	'agents-destroy-orchestration',
	'honest-comparison',
];
const seriesIndex = (id: string) => {
	const baseId = id.replace(/-(en|zh)$/, '');
	const index = seriesOrder.indexOf(baseId);
	return index === -1 ? Number.POSITIVE_INFINITY : index;
};
const bySeriesOrder = (a, b) =>
	seriesIndex(a.id) - seriesIndex(b.id) || b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
const englishPosts = posts.filter((post) => post.data.lang === 'en').sort(bySeriesOrder);
const chinesePosts = posts.filter((post) => post.data.lang === 'zh-CN').sort(bySeriesOrder);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 860px;
			}
			.blog-heading {
				margin-bottom: 2rem;
			}
			.blog-heading h1 {
				margin-bottom: 0.35rem;
				font-size: clamp(2rem, 5vw, 3rem);
				letter-spacing: 0;
			}
			.blog-heading p {
				max-width: 660px;
				margin: 0;
				color: rgb(var(--gray));
				line-height: 1.55;
			}
			.language-section {
				margin-top: 2.5rem;
			}
			.language-section:first-of-type {
				margin-top: 0;
			}
			.language-section h2 {
				margin: 0 0 1rem;
				padding-bottom: 0.65rem;
				border-bottom: 1px solid rgb(var(--gray-light));
				font-size: 1.35em;
				letter-spacing: 0;
			}
			ul {
				display: grid;
				gap: 1rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				border-bottom: 1px solid rgb(var(--gray-light));
				padding: 0 0 1rem;
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li img {
				width: 104px;
				height: 86px;
				margin: 0;
				border-radius: 6px;
				object-fit: cover;
			}
			ul li a {
				display: grid;
				grid-template-columns: 104px 1fr;
				gap: 1rem;
				align-items: center;
			}
			ul li a.text-only {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1.2;
				font-size: 1.3em;
			}
			.date {
				margin: 0.25em 0 0;
				color: rgb(var(--gray));
				font-size: 0.9em;
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: 0 2px 10px rgba(var(--gray), 18%);
			}
			@media (max-width: 720px) {
				ul {
					gap: 1em;
				}
				ul li a {
					grid-template-columns: 72px 1fr;
					gap: 0.8rem;
					text-align: left;
				}
				ul li img {
					width: 72px;
					height: 60px;
				}
				.title {
					font-size: 1.1em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<header class="blog-heading">
				<h1>Blog</h1>
				<p>
					Bilingual essays and notes. English and Chinese versions are grouped separately to
					keep the reading path clear.
				</p>
			</header>
			<section>
				<div class="language-section" id="english-series">
					<h2>English Series</h2>
					<ul>
						{
							englishPosts.map((post) => (
								<li>
									<a class:list={{ 'text-only': !post.data.heroImage }} href={`/blog/${post.id}/`}>
										{post.data.heroImage && (
											<Image width={720} src={post.data.heroImage} alt="" />
										)}
										<h4 class="title">{post.data.title}</h4>
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
									</a>
								</li>
							))
						}
					</ul>
				</div>
				<div class="language-section" id="chinese-series">
					<h2>中文系列</h2>
					<ul>
						{
							chinesePosts.map((post) => (
								<li>
									<a class:list={{ 'text-only': !post.data.heroImage }} href={`/blog/${post.id}/`}>
										{post.data.heroImage && (
											<Image width={720} src={post.data.heroImage} alt="" />
										)}
										<h4 class="title">{post.data.title}</h4>
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
									</a>
								</li>
							))
						}
					</ul>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
