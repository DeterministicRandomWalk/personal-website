---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, lang = 'en' } = Astro.props;
---

<html lang={lang}>
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
				padding-top: 2.5em;
			}
			.hero-image {
				margin: 1.5em auto 2em;
				text-align: center;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				width: min(320px, 100%);
				height: auto;
				border-radius: 8px;
				box-shadow: none;
			}
			.prose {
				width: 760px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 0 1em 3em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin: 0 auto 1.75em;
				padding-bottom: 1.25em;
				border-bottom: 1px solid rgb(var(--gray-light));
				text-align: left;
			}
			.title h1 {
				max-width: 680px;
				margin: 0;
				font-size: clamp(2rem, 5vw, 3rem);
				letter-spacing: 0;
			}
			.date {
				margin-bottom: 0.75em;
				color: rgb(var(--gray));
				font-size: 0.9em;
			}
			.last-updated-on {
				font-style: italic;
			}
			.prose :global(p) {
				margin: 0 0 1.15em;
			}
			.prose :global(h2) {
				margin: 2.2em 0 0.8em;
				padding-top: 0.3em;
				font-size: 1.55em;
				letter-spacing: 0;
			}
			.prose :global(ul),
			.prose :global(ol) {
				margin: 0 0 1.35em;
				padding-left: 1.35em;
			}
			.prose :global(li) {
				margin: 0.35em 0;
			}
			.prose :global(blockquote) {
				margin: 0 0 1.5em;
				padding: 0.85em 1em;
				border-left: 3px solid var(--accent);
				background: rgba(var(--gray-light), 35%);
				border-radius: 0 6px 6px 0;
				font-size: 1em;
			}
			.prose :global(blockquote p) {
				margin: 0;
			}
			.prose table {
				display: block;
				width: 100%;
				overflow-x: auto;
				border-collapse: collapse;
				margin: 1.1em 0 1.8em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				font-size: 0.88em;
			}
			.prose th,
			.prose td {
				padding: 0.65em 0.75em;
				border-right: 1px solid rgb(var(--gray-light));
				border-bottom: 1px solid rgb(var(--gray-light));
				vertical-align: top;
			}
			.prose th:last-child,
			.prose td:last-child {
				border-right: 0;
			}
			.prose tr:last-child td {
				border-bottom: 0;
			}
			.prose th {
				background: rgba(var(--gray-light), 45%);
				border-bottom: 1px solid rgb(var(--gray-light));
				color: rgb(var(--black));
				text-align: left;
			}
			.prose :global(a) {
				text-underline-offset: 0.18em;
			}
			:global(html[lang='zh-CN']) .prose {
				font-family:
					'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', var(--font-atkinson),
					sans-serif;
				line-height: 1.82;
			}
			:global(html[lang='zh-CN']) .prose :global(p) {
				margin-bottom: 1.05em;
			}
			@media (max-width: 720px) {
				main {
					padding-top: 1.25em;
				}
				.prose {
					max-width: calc(100% - 1.25em);
					padding: 0 0.625em 2em;
				}
				.title h1 {
					font-size: 2rem;
				}
				.hero-image img {
					width: min(240px, 85%);
				}
				.prose table {
					font-size: 0.82em;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
					</div>
					{heroImage && <div class="hero-image"><Image width={320} src={heroImage} alt="" /></div>}
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
